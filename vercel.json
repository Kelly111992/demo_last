{
  "version": 2,
  "builds": [
    {
      "src": "demos-ia/api/chat.js",
      "use": "@vercel/node"
    },
    {
      "src": "demos-ia/**/*.{html,css,js,png,jpg,jpeg,svg,ico,mp4,webm}",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/chat",
      "dest": "/demos-ia/api/chat.js"
    },
    {
      "src": "/",
      "dest": "/demos-ia/portada/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/demos-ia/$1"
    }
  ]
}
